# Production/staging: set this in Vercel Project Settings → Environment Variables.
# Local: copy this file to .env and fill the value.
MONGODB_URI="mongodb+srv://<username>:<password>@<cluster-host>/<database-name>?retryWrites=true&w=majority"

# Vite frontend calls Vercel API routes from the same domain.
# Local Vercel dev uses http://localhost:4000 when running `npm run dev`.
VITE_API_URL="http://localhost:4000"
